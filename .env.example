# Copy this file to .env and adjust the values.
# .env is ignored by git — never commit it.

# Directory where doc2kb writes the Obsidian vault and ChromaDB.
# Defaults to <repo>/output if not set.
# DOC2KB_OUTPUT_DIR=/path/to/your/knowledge-base

# Google Vision credentials (only needed for cloud OCR fallback)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
